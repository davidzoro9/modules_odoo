<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ========================================== -->
        <!-- MOODLE CONFIGURATION VIEWS & ACTIONS       -->
        <!-- ========================================== -->

        <!-- Tree View -->
        <record id="view_moodle_configuration_tree" model="ir.ui.view">
            <field name="name">moodle.configuration.tree</field>
            <field name="model">moodle.configuration</field>
            <field name="arch" type="xml">
                <tree string="Moodle Configuration">
                    <field name="name"/>
                    <field name="moodle_url"/>
                    <field name="is_active"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_moodle_configuration_form" model="ir.ui.view">
            <field name="name">moodle.configuration.form</field>
            <field name="model">moodle.configuration</field>
            <field name="arch" type="xml">
                <form string="Moodle Configuration">
                    <header>
                        <button name="sync_courses_action" string="Sync Courses Now" type="object" class="oe_highlight" invisible="not is_active"/>
                        <button name="sync_students_action" string="Sync Students Now" type="object" class="oe_highlight" invisible="not is_active"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="moodle_url"/>
                            </group>
                            <group>
                                <field name="moodle_token" password="True"/>
                                <field name="is_active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Configuration Action -->
        <record id="action_moodle_configuration" model="ir.actions.act_window">
            <field name="name">Moodle Configuration</field>
            <field name="res_model">moodle.configuration</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first active connection with Moodle LMS.
                </p>
            </field>
        </record>

        <!-- ========================================== -->
        <!-- MOODLE SYNC LOG VIEWS & ACTIONS            -->
        <!-- ========================================== -->

        <!-- Tree View -->
        <record id="view_moodle_sync_log_tree" model="ir.ui.view">
            <field name="name">moodle.sync.log.tree</field>
            <field name="model">moodle.sync.log</field>
            <field name="arch" type="xml">
                <tree string="Synchronization Logs" decoration-success="state == 'success'" decoration-danger="state == 'failed'" create="false" edit="false">
                    <field name="date"/>
                    <field name="name"/>
                    <field name="sync_type"/>
                    <field name="direction"/>
                    <field name="state" widget="badge"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_moodle_sync_log_form" model="ir.ui.view">
            <field name="name">moodle.sync.log.form</field>
            <field name="model">moodle.sync.log</field>
            <field name="arch" type="xml">
                <form string="Synchronization Log" create="false" edit="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="date"/>
                                <field name="sync_type"/>
                            </group>
                            <group>
                                <field name="direction"/>
                                <field name="state"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Log Details" name="details">
                                <field name="log_details" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Sync Logs Action -->
        <record id="action_moodle_sync_log" model="ir.actions.act_window">
            <field name="name">Synchronization Logs</field>
            <field name="res_model">moodle.sync.log</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- ========================================== -->
        <!-- PARTNER (STUDENT) VIEW EXTENSION           -->
        <!-- ========================================== -->

        <record id="view_partner_form_moodle_inherit" model="ir.ui.view">
            <field name="name">res.partner.form.moodle.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Moodle LMS Settings" name="moodle_settings">
                        <group>
                            <field name="is_moodle_student"/>
                            <field name="moodle_user_id" readonly="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- ========================================== -->
        <!-- PRODUCT (COURSE) VIEW EXTENSION            -->
        <!-- ========================================== -->

        <record id="product_template_form_view_moodle_inherit" model="ir.ui.view">
            <field name="name">product.template.form.moodle.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Moodle LMS Settings" name="moodle_settings">
                        <group>
                            <field name="is_moodle_course"/>
                            <field name="moodle_course_id" readonly="1"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- ========================================== -->
        <!-- MENU DEFINITIONS                           -->
        <!-- ========================================== -->

        <!-- Root Menu -->
        <menuitem id="menu_moodle_root" name="Moodle Integration" web_icon="projet_01_integration_odoo_moodle_lms,static/description/icon.png" sequence="100"/>

        <!-- Logs Menu -->
        <menuitem id="menu_moodle_logs" name="Sync Logs" parent="menu_moodle_root" action="action_moodle_sync_log" sequence="10"/>

        <!-- Settings Category -->
        <menuitem id="menu_moodle_config_cat" name="Configuration" parent="menu_moodle_root" sequence="50"/>

        <!-- Settings Menu -->
        <menuitem id="menu_moodle_config" name="Connection Config" parent="menu_moodle_config_cat" action="action_moodle_configuration" sequence="10"/>

    </data>
</odoo>
