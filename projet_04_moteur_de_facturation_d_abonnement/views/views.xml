        <!-- Action for Moteur de Facturation d'Abonnement -->
        <record id="action_moteur_de_facturation_d_abonnement" model="ir.actions.act_window">
            <field name="name">Moteur de Facturation d'Abonnement</field>
            <field name="res_model">portfolio.moteur.de.facturation.d.abonnement</field>
            <field name="view_mode">list,form</field>
