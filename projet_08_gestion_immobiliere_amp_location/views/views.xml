<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View for Gestion Immobilière &amp;amp; Location -->
        <record id="view_gestion_immobiliere_amp_location_tree" model="ir.ui.view">
            <field name="name">property.contract.tree</field>
            <field name="model">property.contract</field>
            <field name="arch" type="xml">
                <tree string="Gestion Immobilière &amp;amp; Location">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Gestion Immobilière &amp;amp; Location -->
        <record id="view_gestion_immobiliere_amp_location_form" model="ir.ui.view">
            <field name="name">property.contract.form</field>
            <field name="model">property.contract</field>
            <field name="arch" type="xml">
                <form string="Gestion Immobilière &amp;amp; Location">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action for Gestion Immobilière &amp;amp; Location -->
        <record id="action_gestion_immobiliere_amp_location" model="ir.actions.act_window">
            <field name="name">Gestion Immobilière &amp;amp; Location</field>
            <field name="res_model">property.contract</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
