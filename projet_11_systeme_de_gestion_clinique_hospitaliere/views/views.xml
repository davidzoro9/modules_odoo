<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View for Système de Gestion Clinique Hospitalière -->
        <record id="view_systeme_de_gestion_clinique_hospitaliere_tree" model="ir.ui.view">
            <field name="name">medical.consultation.tree</field>
            <field name="model">medical.consultation</field>
            <field name="arch" type="xml">
                <list string="Système de Gestion Clinique Hospitalière">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form View for Système de Gestion Clinique Hospitalière -->
        <record id="view_systeme_de_gestion_clinique_hospitaliere_form" model="ir.ui.view">
            <field name="name">medical.consultation.form</field>
            <field name="model">medical.consultation</field>
            <field name="arch" type="xml">
                <form string="Système de Gestion Clinique Hospitalière">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action for Système de Gestion Clinique Hospitalière -->
        <record id="action_systeme_de_gestion_clinique_hospitaliere" model="ir.actions.act_window">
            <field name="name">Système de Gestion Clinique Hospitalière</field>
            <field name="res_model">medical.consultation</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
