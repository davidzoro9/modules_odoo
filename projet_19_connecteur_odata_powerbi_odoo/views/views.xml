<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View for Connecteur OData PowerBI - Odoo -->
        <record id="view_connecteur_odata_powerbi_odoo_tree" model="ir.ui.view">
            <field name="name">portfolio.connecteur.odata.powerbi.odoo.tree</field>
            <field name="model">portfolio.connecteur.odata.powerbi.odoo</field>
            <field name="arch" type="xml">
                <tree string="Connecteur OData PowerBI - Odoo">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Connecteur OData PowerBI - Odoo -->
        <record id="view_connecteur_odata_powerbi_odoo_form" model="ir.ui.view">
            <field name="name">portfolio.connecteur.odata.powerbi.odoo.form</field>
            <field name="model">portfolio.connecteur.odata.powerbi.odoo</field>
            <field name="arch" type="xml">
                <form string="Connecteur OData PowerBI - Odoo">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action for Connecteur OData PowerBI - Odoo -->
        <record id="action_connecteur_odata_powerbi_odoo" model="ir.actions.act_window">
            <field name="name">Connecteur OData PowerBI - Odoo</field>
            <field name="res_model">portfolio.connecteur.odata.powerbi.odoo</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
