<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View for Synchronisation HubSpot CRM - Odoo -->
        <record id="view_synchronisation_hubspot_crm_odoo_tree" model="ir.ui.view">
            <field name="name">hubspot.connector.tree</field>
            <field name="model">hubspot.connector</field>
            <field name="arch" type="xml">
                <list string="Synchronisation HubSpot CRM - Odoo">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form View for Synchronisation HubSpot CRM - Odoo -->
        <record id="view_synchronisation_hubspot_crm_odoo_form" model="ir.ui.view">
            <field name="name">hubspot.connector.form</field>
            <field name="model">hubspot.connector</field>
            <field name="arch" type="xml">
                <form string="Synchronisation HubSpot CRM - Odoo">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action for Synchronisation HubSpot CRM - Odoo -->
        <record id="action_synchronisation_hubspot_crm_odoo" model="ir.actions.act_window">
            <field name="name">Synchronisation HubSpot CRM - Odoo</field>
            <field name="res_model">hubspot.connector</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
