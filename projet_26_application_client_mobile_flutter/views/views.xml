<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View for Application Client Mobile (Flutter) -->
        <record id="view_application_client_mobile_flutter_tree" model="ir.ui.view">
            <field name="name">mobile.push.notification.tree</field>
            <field name="model">mobile.push.notification</field>
            <field name="arch" type="xml">
                <list string="Application Client Mobile (Flutter)">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form View for Application Client Mobile (Flutter) -->
        <record id="view_application_client_mobile_flutter_form" model="ir.ui.view">
            <field name="name">mobile.push.notification.form</field>
            <field name="model">mobile.push.notification</field>
            <field name="arch" type="xml">
                <form string="Application Client Mobile (Flutter)">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action for Application Client Mobile (Flutter) -->
        <record id="action_application_client_mobile_flutter" model="ir.actions.act_window">
            <field name="name">Application Client Mobile (Flutter)</field>
            <field name="res_model">mobile.push.notification</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
