<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherited View for Commandes Inter-Compagnies Automatisées -->
        <record id="view_commandes_inter_compagnies_automatisees_inherit" model="ir.ui.view">
            <field name="name">sale.order.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="Commandes Inter-Compagnies Automatisées">
                        <!-- Custom fields or status added by portfolio module -->
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
